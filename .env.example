# Backend server
ADDR=:8080
DB_PATH=data/demo.db
DEMO_TIME_ANCHOR=2025-02-15T00:00:00Z

# Semantic provider mode
SEMANTIC_PROVIDER=slm-superlinked
REWRITE_INTENT_MODELS_PATH=config/rewrite_intent_models.json
REWRITE_INTENT_PROVIDER_DEFAULT=
RETRIEVAL_MODELS_PATH=config/retrieval_models.json
IDENTIFIER_FAST_PATH_ENABLED=true
IDENTIFIER_GROUPED_RESPONSE_ENABLED=true
IDENTIFIER_PATTERNS_PATH=config/identifier_patterns.json
QUERY_SHAPE_THRESHOLDS_PATH=config/query_shape_thresholds.json

# Superlinked adapter
SUPERLINKED_ENDPOINT=http://localhost:8080/api/mock/superlinked
SUPERLINKED_TIMEOUT_MS=1500
SUPERLINKED_MODE=shadow
SUPERLINKED_MIN_CONFIDENCE=0.55
SUPERLINKED_MAX_LATENCY_MS=120
SUPERLINKED_TOPK=100
SUPERLINKED_POST_MERGE_CAP=300

# Local SLM rewrite (Ollama)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_TIMEOUT_MS=1500
OLLAMA_QWEN_MODEL=qwen2.5:7b-instruct
OLLAMA_QWEN_TIMEOUT_MS=2400
OLLAMA_LLAMA_MODEL=llama3.1:8b-instruct
OLLAMA_LLAMA_TIMEOUT_MS=2600

# Embeddings + hybrid retrieval
EMBEDDING_PROVIDER=ollama_embed
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_MS=1200
RETRIEVAL_MODE=hybrid_gated
RETRIEVAL_MIN_CONFIDENCE=0.50
RETRIEVAL_MAX_LATENCY_MS=150
RETRIEVAL_TOPK_VECTOR=120
RETRIEVAL_TOPK_LEXICAL=120
RETRIEVAL_FUSION_CAP=300
